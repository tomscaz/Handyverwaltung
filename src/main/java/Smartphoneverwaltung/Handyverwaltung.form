<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="Smartphoneverwaltung.Handyverwaltung">
  <grid id="root" binding="panelHaupt" layout-manager="GridLayoutManager" row-count="6" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="10" vgap="10">
    <margin top="15" left="15" bottom="15" right="15"/>
    <constraints>
      <xy x="20" y="20" width="700" height="620"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="titel" class="javax.swing.JLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font name="Segoe UI" size="20" style="1"/>
          <text value="Smartphone-Verwaltung"/>
        </properties>
      </component>
      <grid id="eingabe" layout-manager="GridLayoutManager" row-count="6" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="10" vgap="8">
        <margin top="10" left="10" bottom="10" right="10"/>
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="etched"/>
        <children>
          <component id="lblModell" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Modell:"/>
            </properties>
          </component>
          <component id="modellFeld" class="javax.swing.JTextField" binding="modellFeld">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="250" height="30"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="lblHersteller" class="javax.swing.JLabel">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Hersteller:"/>
            </properties>
          </component>
          <component id="herstellerBox" class="javax.swing.JComboBox" binding="herstellerBox">
            <constraints>
              <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
          <component id="lblOs" class="javax.swing.JLabel">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Betriebssystem:"/>
            </properties>
          </component>
          <component id="osBox" class="javax.swing.JComboBox" binding="osBox">
            <constraints>
              <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
          <component id="lblPreis" class="javax.swing.JLabel">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Preis (€):"/>
            </properties>
          </component>
          <component id="preisFeld" class="javax.swing.JTextField" binding="preisFeld">
            <constraints>
              <grid row="3" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="250" height="30"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="lagerCheck" class="javax.swing.JCheckBox" binding="lagerCheck">
            <constraints>
              <grid row="4" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Auf Lager"/>
            </properties>
          </component>
          <component id="speichernButton" class="javax.swing.JButton" binding="speichernButton">
            <constraints>
              <grid row="5" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="-1" height="35"/>
              </grid>
            </constraints>
            <properties>
              <font style="1"/>
              <text value="Speichern"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="filterZeile" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="10" vgap="0">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="lblFilter" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Filter (Hersteller):"/>
            </properties>
          </component>
          <component id="filterBox" class="javax.swing.JComboBox" binding="filterBox">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
          <component id="auswertenButton" class="javax.swing.JButton" binding="auswertenButton">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Auswerten"/>
            </properties>
          </component>
        </children>
      </grid>
      <scrollpane id="listeScroll">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="line" title="Vorhandene Smartphones"/>
        <children>
          <component id="liste" class="javax.swing.JList" binding="liste">
            <constraints/>
            <properties>
              <selectionMode value="0"/>
            </properties>
          </component>
        </children>
      </scrollpane>
      <component id="ausgabeLabel" class="javax.swing.JLabel" binding="ausgabeLabel">
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Auswertung: -"/>
        </properties>
      </component>
      <grid id="loeschZeile" layout-manager="GridLayoutManager" row-count="1" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="10" vgap="0">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="auswahlLoeschenButton" class="javax.swing.JButton" binding="auswahlLoeschenButton">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Auswahl entfernen"/>
            </properties>
          </component>
          <component id="allesLoeschenButton" class="javax.swing.JButton" binding="allesLoeschenButton">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Alles zurücksetzen"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
